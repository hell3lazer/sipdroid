<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Top Right Settings Button -->
    <ImageButton
        android:id="@+id/settings_button"
        android:src="@drawable/ic_preferences_24"
        app:tint="?android:attr/textColorPrimary"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="center"
        android:layout_alignParentRight="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:contentDescription="@string/menu_settings" />

    <!-- Header area -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">
        
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/icon"
            android:layout_marginBottom="16dp"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/app_name"/>
    </LinearLayout>

    <!-- Content area -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint2"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            android:layout_marginBottom="24dp">
            <org.sipdroid.sipua.ui.InstantAutoCompleteTextView
                android:id="@+id/txt_callee2"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:textColor="?android:attr/textColorPrimary"
                android:singleLine="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="phone"
                android:imeOptions="actionSend"/>
        </com.google.android.material.textfield.TextInputLayout>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            android:layout_marginBottom="32dp">
            <org.sipdroid.sipua.ui.InstantAutoCompleteTextView
                android:id="@+id/txt_callee"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:textColor="?android:attr/textColorPrimary"
                android:singleLine="true"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textEmailAddress"
                android:imeOptions="actionSend"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_button" 
            android:layout_width="match_parent" 
            android:layout_height="64dp" 
            app:cornerRadius="32dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="@string/menu_create" />
            
    </LinearLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp">
        
        <ImageButton
            android:id="@+id/contacts_button"
            android:src="@drawable/ic_dialpad_24"
            app:tint="?android:attr/textColorPrimary"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:scaleType="fitCenter"
            android:padding="16dp"
            android:contentDescription="Contacts" />
            
    </LinearLayout>

</RelativeLayout>

